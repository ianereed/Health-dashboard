<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.home-tools.finance-monitor-watcher</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/homeserver/Home-Tools/finance-monitor/.venv/bin/python3</string>
    <string>/Users/homeserver/Home-Tools/finance-monitor/main.py</string>
    <string>watch</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/homeserver/Home-Tools/finance-monitor</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>KEYCHAIN_PATH</key>
    <string>/Users/homeserver/Library/Keychains/login.keychain-db</string>
  </dict>

  <!-- Scan intake/ every 5 minutes -->
  <key>StartInterval</key>
  <integer>300</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/tmp/home-tools-finance-monitor-watcher.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/home-tools-finance-monitor-watcher-error.log</string>
</dict>
</plist>
