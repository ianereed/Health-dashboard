\outl0\strokewidth0 \strokec2 Sending emails requires confirmation (not auto-send)\cb1 \
\ls31\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Shell command execution is either disabled or limited to a specific allowlist\cb1 \
