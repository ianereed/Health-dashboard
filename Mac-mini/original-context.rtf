\f2\b\fs24 \cf2 \cb3 \strokec2 The matching logic in practice
\f1\b0 \cb1 \
\pard\pardeftab720\partightenfactor0
\cf2 \cb3 Amazon orders rarely match YNAB transactions 1:1\'a0because:\cb1 \
\pard\tx220\tx720\pardeftab720\li720\fi-720\partightenfactor0
\ls16\ilvl0\cf2 \cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Multi-item orders often charge separately per shipment\cb1 \
\ls16\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Amazon sometimes splits a single order across multiple cards or dates\cb1 \
\ls16\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Returns and credits show up asynchronously\cb1 \
\ls16\ilvl0\cb3 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Gift cards and promotional credits muddy the total\cb1 \
\pard\pardeftab720\partightenfactor0
\cf2 \cb3 So your reconciliation script needs fuzzy matching \'97 same date \'b1 3 days, same total amount, Amazon payee pattern. When it finds a match, the magic happens: Ollama reads the item descriptions from the Amazon order and suggests a YNAB category.\cb1 \
\pard\pardeftab720\partightenfactor0

