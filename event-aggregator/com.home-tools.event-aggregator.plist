<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.home-tools.event-aggregator</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/homeserver/Home-Tools/event-aggregator/.venv/bin/python3</string>
    <string>/Users/homeserver/Home-Tools/event-aggregator/main.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/homeserver/Home-Tools/event-aggregator</string>

  <!-- Run every 10 minutes -->
  <key>StartInterval</key>
  <integer>600</integer>

  <key>StandardOutPath</key>
  <string>/tmp/home-tools-event-aggregator.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/home-tools-event-aggregator-error.log</string>

  <key>RunAtLoad</key>
  <false/>

  <key>KeepAlive</key>
  <false/>
</dict>
</plist>
