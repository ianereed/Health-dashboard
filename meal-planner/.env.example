# Todoist
TODOIST_API_TOKEN=your_todoist_api_token_here
TODOIST_PROJECT_ID=123456789
# JSON map of Todoist section names to their IDs
TODOIST_SECTIONS={"Produce":"2345678","Dairy":"2345679","Meat":"2345680","Pantry":"2345681","Frozen":"2345682","Other":"2345683"}
# Label applied to all auto-created tasks (must exist in Todoist)
TODOIST_LABEL=meal-planner

# Gemini (used by consolidate.py and Apps Script)
# Free key at aistudio.google.com — no billing required
GEMINI_API_KEY=AIza...

# Bulk photo import (used by bulk_import.py)
# Get URL from: Extensions > Apps Script > Deploy > Manage deployments > Web app URL
# See apps-script/SETUP.md for deployment instructions
APPS_SCRIPT_WEBAPP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
# Optional: set same value as BULK_IMPORT_SECRET in Apps Script Script Properties to gate access
BULK_IMPORT_SECRET=
