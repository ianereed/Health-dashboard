# Slack — dedicated "Home Router Bot" app, Socket Mode enabled.
# For live setup, store tokens in the mini's login keychain instead:
#   security add-generic-password -U -s dispatcher-slack -a app_token -w "xapp-..." \
#     ~/Library/Keychains/login.keychain-db
#   security add-generic-password -U -s dispatcher-slack -a bot_token -w "xoxb-..." \
#     ~/Library/Keychains/login.keychain-db
# Tokens in .env are fine for local dev.
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Channels the bot listens in. Can be channel names (without #) or raw Slack IDs.
INTERACTIVE_CHANNEL=ian-event-aggregator
IMAGE_INTAKE_CHANNEL=ian-image-intake

# Comma-separated Slack user IDs allowed to trigger commands. Empty = any
# workspace member (logs a warning).
ALLOWED_SLACK_USER_IDS=

# Paths to the sibling projects. Defaults assume the mini layout. Override for
# the laptop dev environment.
EVENT_AGGREGATOR_DIR=/Users/homeserver/Home-Tools/event-aggregator
EVENT_AGGREGATOR_PYTHON=/Users/homeserver/Home-Tools/event-aggregator/.venv/bin/python3
FINANCE_MONITOR_INTAKE=/Users/homeserver/Home-Tools/finance-monitor/intake

# Where files stage on the mini until a NAS is mounted. Each category gets a
# subdir. Flush to NAS later when /Volumes/Share1 is available.
NAS_STAGING_DIR=
